    "input": {
      "messages": [
        {"role": "user", "content": "Create a concert event called Rock Night at Arena Belgrade for next Saturday with 1000 capacity and 2500 RSD tickets"}
      ]
    },
    "assertions": {
      "expected_tool": "createEvent",
      "response_not_empty": true
    }
  },
  {
